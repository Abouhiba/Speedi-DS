{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/icons/**",
              "components/core/**",
              "components/kit/**",
              "guidelines/**",
              "ui_kits/app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|Alexandria|IBM Plex Sans Arabic|Poppins|Cairo))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, Alexandria, IBM Plex Sans Arabic, Poppins, Cairo."
      },
      {
        "selector": "JSXOpeningElement[name.name='Add'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|property1|key|ref|className|style|children)$/]",
        "message": "<Add> doesn't accept that prop. Declared props: className, style, property1."
      },
      {
        "selector": "JSXOpeningElement[name.name='Add'] > JSXAttribute[name.name='property1'] > Literal[value!=/^(?:bold|broken|bulk|linear|outline|twotone)$/]",
        "message": "<Add> property1 must be one of 'bold' | 'broken' | 'bulk' | 'linear' | 'outline' | 'twotone'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowSquareDown'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|property1|key|ref|className|style|children)$/]",
        "message": "<ArrowSquareDown> doesn't accept that prop. Declared props: className, style, property1."
